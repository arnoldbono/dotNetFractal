<Window x:Class="dotNetFractal.WPF.FractalAreaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dotNetFractal.WPF"
        mc:Ignorable="d"
        Title="Fractal Area" Height="220" Width="240" ResizeMode="NoResize">
    <Window.DataContext>
        <local:FractalAreaViewModel />
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition  Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Label Grid.Column="0" Grid.Row="0" Content="Min X:"  VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="0" TextWrapping="Wrap" Text="{Binding MinX}" Width="120" HorizontalAlignment="Left" VerticalAlignment="Center" />
            <Label Grid.Column="0" Grid.Row="1" Content="Min Y:"  VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="1" TextWrapping="Wrap" Text="{Binding MinY}" Width="120" HorizontalAlignment="Left" VerticalAlignment="Center" />
            <Label Grid.Column="0" Grid.Row="2" Content="Max X:"  VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="2" TextWrapping="Wrap" Text="{Binding MaxX}" Width="120" HorizontalAlignment="Left" VerticalAlignment="Center" />
            <Label Grid.Column="0" Grid.Row="3" Content="Max Y:"  VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="3" TextWrapping="Wrap" Text="{Binding MaxY}" Width="120" HorizontalAlignment="Left" VerticalAlignment="Center" />
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition  Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Label Grid.Column="0" Grid.Row="0" Content="Plate:"  VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" Grid.Row="0" Width="100" SelectedIndex="{Binding SelectedPlate}" HorizontalAlignment="Right" VerticalAlignment="Center">
                <ComboBoxItem Content="Plate 4" />
                <ComboBoxItem Content="Plate 5" />
                <ComboBoxItem Content="Plate 5a" />
                <ComboBoxItem Content="Plate 6" />
                <ComboBoxItem Content="Plate 7" />
                <ComboBoxItem Content="Plate 7a" />
                <ComboBoxItem Content="Plate 8" />
                <ComboBoxItem Content="Plate 9" />
            </ComboBox>
        </Grid>
        <StackPanel Grid.Row="2" Margin="10,10,10,10" Orientation="Horizontal" HorizontalAlignment="Right" >
            <Button Content="Cancel" IsCancel="True" Width="60" Margin="0,0,10,0" />
            <Button Content="OK" IsDefault="True" Width="60" Command="{Binding AcceptCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}" />
        </StackPanel>
    </Grid>
</Window>
