<UserControl x:Class="dotNetFractal.WPF.Presentation.DisplaySettingsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:dotNetFractal.WPF"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:DisplaySettingsViewModel, IsDesignTimeCreatable=True}">
    <GroupBox Header="Image Display:">
        <CheckBox Content="Stretch image to window size" 
                  IsChecked="{Binding StretchImage}" 
                  Margin="5" />
    </GroupBox>
</UserControl>
