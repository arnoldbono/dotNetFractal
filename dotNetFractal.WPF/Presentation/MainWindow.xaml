<Window x:Class="dotNetFractal.WPF.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dotNetFractal.WPF.Presentation"
        xmlns:presentation="clr-namespace:dotNetFractal.WPF.Presentation"
        xmlns:vm="clr-namespace:dotNetFractal.WPF.ViewModels"
        xmlns:converters="clr-namespace:dotNetFractal.WPF"
        mc:Ignorable="d"
        Title=".NET Fractal (WPF Version)" Height="450" Width="800"
        WindowStyle="{Binding WindowStyle}"
        WindowState="{Binding WindowState}">
    <Window.Resources>
        <converters:BoolToStretchConverter x:Key="BoolToStretchConverter" />
        <converters:BoolToScrollBarVisibilityConverter x:Key="BoolToScrollBarVisibilityConverter" />
        <converters:BoolToAlignmentConverter x:Key="BoolToAlignmentConverter" />
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <converters:BoolToColumnSpanConverter x:Key="BoolToColumnSpanConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.InputBindings>
        <KeyBinding Command="{Binding GoBackCommand}" Key="Z" Modifiers="Ctrl" />
        <KeyBinding Command="{Binding GoForwardCommand}" Key="Y" Modifiers="Ctrl" />
        <KeyBinding Command="{Binding ToggleStretchImageCommand}" Key="F10" />
        <KeyBinding Command="{Binding ToggleFullScreenCommand}" Key="F11" />
        <KeyBinding Command="{Binding TogglePropertiesPanelCommand}" Key="F2" />
        <KeyBinding Command="{Binding StopSelectionCommand}" Key="Esc" />
    </Window.InputBindings>
    <DockPanel>
        <Menu DockPanel.Dock="Top" Visibility="{Binding IsFullScreen, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="{Binding NewFractalCommand}" />
                <MenuItem Header="Save _As" Command="{Binding SaveAsCommand}" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo (Go Back)" Command="{Binding GoBackCommand}" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Redo (Go Forward)" Command="{Binding GoForwardCommand}" InputGestureText="Ctrl+Y"/>
                <Separator />
                <MenuItem Header="_Copy" Command="{Binding CopyCommand}"/>
            </MenuItem>
        </Menu>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="300" MinWidth="200" MaxWidth="500"/>
            </Grid.ColumnDefinitions>

            <!-- Main Content Area -->
            <ScrollViewer Grid.Column="0"
                          Grid.ColumnSpan="{Binding ArePropertiesExpanded, Converter={StaticResource BoolToColumnSpanConverter}}"
                          HorizontalScrollBarVisibility="{Binding StretchImage, Converter={StaticResource BoolToScrollBarVisibilityConverter}}" 
                          VerticalScrollBarVisibility="{Binding StretchImage, Converter={StaticResource BoolToScrollBarVisibilityConverter}}">
                <Grid>
                    <Image x:Name="FractalImage" 
                           Stretch="{Binding StretchImage, Converter={StaticResource BoolToStretchConverter}}" 
                           Source="{Binding MainImage}" 
                           VerticalAlignment="{Binding StretchImage, Converter={StaticResource BoolToAlignmentConverter}}" 
                           HorizontalAlignment="{Binding StretchImage, Converter={StaticResource BoolToAlignmentConverter}}"/>
                    <Canvas x:Name="SelectionCanvas" 
                            Background="Transparent"
                            IsEnabled="{Binding StretchImage, Converter={StaticResource InverseBooleanConverter}}"
                            MouseLeftButtonDown="SelectionCanvas_MouseLeftButtonDown"
                            MouseMove="SelectionCanvas_MouseMove"
                            MouseLeftButtonUp="SelectionCanvas_MouseLeftButtonUp"
                            VerticalAlignment="Top" 
                            HorizontalAlignment="Left">
                        <Rectangle x:Name="SelectionRectangle" 
                                   Stroke="White" 
                                   StrokeThickness="2" 
                                   StrokeDashArray="4,2"
                                   Fill="Transparent" 
                                   Visibility="Collapsed"/>
                    </Canvas>
                </Grid>
            </ScrollViewer>

            <!-- GridSplitter for resizing Properties Panel -->
            <GridSplitter Grid.Column="1" 
                          Width="5" 
                          HorizontalAlignment="Stretch" 
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ShowsPreview="False">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <!-- Hide splitter if panel is not visible OR if collapsed -->
                            <DataTrigger Binding="{Binding IsPropertiesPanelVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ArePropertiesExpanded}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <!-- Properties Panel UserControl -->
            <presentation:PropertiesPanel Grid.Column="2" DataContext="{Binding PropertiesPanelViewModel}" />

            <!-- Progress Bar Overlay -->
            <ProgressBar Minimum="0" 
                                 Maximum="100" 
                                 Value="{Binding ComputationProgress}"
                                 Height="30"
                                 Margin="20"
                                 VerticalAlignment="Bottom"
                                 HorizontalAlignment="Stretch"
                                 Visibility="{Binding IsComputing, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </Grid>
    </DockPanel>
</Window>
