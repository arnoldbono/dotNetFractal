<Window x:Class="dotNetFractal.WPF.FractalSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dotNetFractal.WPF"
        xmlns:vm="clr-namespace:dotNetFractal.WPF.ViewModels"
        mc:Ignorable="d"
        Title="Fractal Settings" 
        SizeToContent="WidthAndHeight" 
        MinWidth="280" 
        MinHeight="180" 
        MaxWidth="400" 
        MaxHeight="300" 
        ResizeMode="NoResize">
    <Window.DataContext>
        <vm:FractalSettingsViewModel />
    </Window.DataContext>
    <Grid Margin="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <GroupBox Header="Settings:" Grid.Row="0">
            <Grid Margin="0,5,0,0" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Content="Max Iterations:" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left"/>
                <TextBox Text="{Binding MaxIterations}" Width="80" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                <Label Content="Max Color Steps:" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Left"/>
                <TextBox Text="{Binding MaxColorSteps}" Width="80" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                <CheckBox Content="Smooth Coloring" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" IsChecked="{Binding SmoothColoring}" VerticalAlignment="Center" Margin="5,5,0,0"/>
                <CheckBox Content="High Precision" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" IsChecked="{Binding HighPrecision}" VerticalAlignment="Center" Margin="5,5,0,0"/>
            </Grid>
        </GroupBox>
        <StackPanel Grid.Row="1" Margin="0,5,0,0" Orientation="Horizontal" HorizontalAlignment="Right" >
            <Button Content="Cancel" IsCancel="True" Width="60" Margin="0,0,10,0" />
            <Button Content="OK" IsDefault="True" Width="60" Command="{Binding AcceptCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}" />
        </StackPanel>
    </Grid>
</Window>
