<Window x:Class="dotNetFractal.WPF.DisplaySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dotNetFractal.WPF"
        mc:Ignorable="d"
        Title="Display Settings" 
        SizeToContent="WidthAndHeight" 
        MinWidth="240" 
        MinHeight="150" 
        MaxWidth="400" 
        MaxHeight="300" 
        ResizeMode="NoResize"
        d:DataContext="{d:DesignInstance Type=local:DisplaySettingsViewModel, IsDesignTimeCreatable=True}">
    <Grid Margin="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <GroupBox Header="Image Display:" Grid.Row="0">
            <CheckBox Content="Stretch image to window size" IsChecked="{Binding StretchImage}" Margin="5" />
        </GroupBox>
        <StackPanel Grid.Row="1" Margin="0,10,0,0" Orientation="Horizontal" HorizontalAlignment="Right" >
            <Button Content="Cancel" IsCancel="True" Width="60" Margin="0,0,10,0" />
            <Button Content="OK" IsDefault="True" Width="60" Command="{Binding AcceptCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}" />
        </StackPanel>
    </Grid>
</Window>
