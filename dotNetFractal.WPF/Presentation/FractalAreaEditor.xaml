<UserControl x:Class="dotNetFractal.WPF.Presentation.FractalAreaEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:dotNetFractal.WPF"
             xmlns:vm="clr-namespace:dotNetFractal.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:FractalAreaViewModel, IsDesignTimeCreatable=True}">
    <UserControl.Resources>
        <local:FractalUnitConverter x:Key="FractalUnitConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Coordinates Grid -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Label Grid.Column="0" Grid.Row="0" Content="Cx:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="0" TextWrapping="Wrap" Text="{Binding Cx, Converter={StaticResource FractalUnitConverter}}" Margin="2" VerticalAlignment="Center" />
            <Label Grid.Column="0" Grid.Row="1" Content="Cy:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="1" TextWrapping="Wrap" Text="{Binding Cy, Converter={StaticResource FractalUnitConverter}}" Margin="2" VerticalAlignment="Center" />
            <Label Grid.Column="0" Grid.Row="2" Content="Center X:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="2" TextWrapping="Wrap" Text="{Binding CenterX, Converter={StaticResource FractalUnitConverter}}" Margin="2" VerticalAlignment="Center" />
            <Label Grid.Column="0" Grid.Row="3" Content="Center Y:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="3" TextWrapping="Wrap" Text="{Binding CenterY, Converter={StaticResource FractalUnitConverter}}" Margin="2" VerticalAlignment="Center" />
            <Label Grid.Column="0" Grid.Row="4" Content="Width:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="4" TextWrapping="Wrap" Text="{Binding Width, Converter={StaticResource FractalUnitConverter}}" Margin="2" VerticalAlignment="Center" />
            <Label Grid.Column="0" Grid.Row="5" Content="Height:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="5" TextWrapping="Wrap" Text="{Binding Height, Converter={StaticResource FractalUnitConverter}}" Margin="2" VerticalAlignment="Center" />
        </Grid>

        <!-- Plate and Julia Set -->
        <Grid Grid.Row="1" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Label Grid.Column="0" Grid.Row="0" Content="Plate:" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" Grid.Row="0" SelectedIndex="{Binding SelectedPlate}" ItemsSource="{Binding Plates}" Margin="2" VerticalAlignment="Center" />
            <CheckBox Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Content="Julia Set" IsChecked="{Binding JuliaSet}" Margin="2,5,2,2" />
        </Grid>
    </Grid>
</UserControl>
