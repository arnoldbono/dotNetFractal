<Window x:Class="dotNetFractal.WPF.ImageResolutionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dotNetFractal.WPF"
        xmlns:presentation="clr-namespace:dotNetFractal.WPF.Presentation"
        mc:Ignorable="d"
        Title="Image Resolution" 
        SizeToContent="WidthAndHeight" 
        MinWidth="240" 
        MinHeight="220" 
        MaxWidth="400" 
        MaxHeight="300" 
        ResizeMode="NoResize">
    <Window.DataContext>
        <local:ImageResolutionViewModel />
    </Window.DataContext>
    <Grid Margin="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Image Resolution Editor Control -->
        <presentation:ImageResolutionEditor Grid.Row="0" />

        <!-- OK/Cancel Buttons -->
        <StackPanel Grid.Row="1" Margin="0,5,0,0" Orientation="Horizontal" HorizontalAlignment="Right" >
            <Button Content="Cancel" IsCancel="True" Width="60" Margin="0,0,10,0" />
            <Button Content="OK" IsDefault="True" Width="60" Command="{Binding AcceptCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}" />
        </StackPanel>
    </Grid>
</Window>
