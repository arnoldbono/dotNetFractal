<Window x:Class="dotNetFractal.WPF.FractalAreaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dotNetFractal.WPF"
        xmlns:presentation="clr-namespace:dotNetFractal.WPF.Presentation"
        xmlns:vm="clr-namespace:dotNetFractal.WPF.ViewModels"
        mc:Ignorable="d"
        Title="Fractal Area"
        SizeToContent="WidthAndHeight" 
        MinWidth="240" 
        MinHeight="220" 
        MaxWidth="500" 
        MaxHeight="300" 
        ResizeMode="NoResize"
        d:DataContext="{d:DesignInstance Type=vm:FractalAreaViewModel, IsDesignTimeCreatable=True}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Fractal Area Editor Control -->
        <presentation:FractalAreaEditor Grid.Row="0" Margin="10" />

        <!-- OK/Cancel Buttons -->
        <StackPanel Grid.Row="1" Margin="10,0,10,10" Orientation="Horizontal" HorizontalAlignment="Right" >
            <Button Content="Cancel" IsCancel="True" Width="60" Margin="0,0,10,0" />
            <Button Content="OK" IsDefault="True" Width="60" Command="{Binding AcceptCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}" />
        </StackPanel>
    </Grid>
</Window>
