<Window x:Class="dotNetFractal.WPF.FractalAreaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dotNetFractal.WPF"
        xmlns:vm="clr-namespace:dotNetFractal.WPF.ViewModels"
        mc:Ignorable="d"
        Title="Fractal Area"
        SizeToContent="WidthAndHeight" 
        MinWidth="240" 
        MinHeight="220" 
        MaxWidth="500" 
        MaxHeight="300" 
        ResizeMode="NoResize"
        d:DataContext="{d:DesignInstance Type=vm:FractalAreaViewModel, IsDesignTimeCreatable=True}">
    <Window.Resources>
        <local:FractalUnitConverter x:Key="FractalUnitConverter" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition  Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Label Grid.Column="0" Grid.Row="0" Content="Cx:"  VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="0" TextWrapping="Wrap" Text="{Binding Cx, Converter={StaticResource FractalUnitConverter}}" Width="120" HorizontalAlignment="Left" VerticalAlignment="Center" />
            <Label Grid.Column="0" Grid.Row="1" Content="Cy:"  VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="1" TextWrapping="Wrap" Text="{Binding Cy, Converter={StaticResource FractalUnitConverter}}" Width="120" HorizontalAlignment="Left" VerticalAlignment="Center" />
            <Label Grid.Column="0" Grid.Row="2" Content="Center X:"  VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="2" TextWrapping="Wrap" Text="{Binding CenterX, Converter={StaticResource FractalUnitConverter}}" Width="120" HorizontalAlignment="Left" VerticalAlignment="Center" />
            <Label Grid.Column="0" Grid.Row="3" Content="Center Y:"  VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="3" TextWrapping="Wrap" Text="{Binding CenterY, Converter={StaticResource FractalUnitConverter}}" Width="120" HorizontalAlignment="Left" VerticalAlignment="Center" />
            <Label Grid.Column="0" Grid.Row="4" Content="Width:"  VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="4" TextWrapping="Wrap" Text="{Binding Width, Converter={StaticResource FractalUnitConverter}}" Width="120" HorizontalAlignment="Left" VerticalAlignment="Center" />
            <Label Grid.Column="0" Grid.Row="5" Content="Height:"  VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="5" TextWrapping="Wrap" Text="{Binding Height, Converter={StaticResource FractalUnitConverter}}" Width="120" HorizontalAlignment="Left" VerticalAlignment="Center" />
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition  Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Label Grid.Column="0" Grid.Row="0" Content="Plate:"  VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" Grid.Row="0" SelectedIndex="{Binding SelectedPlate}" ItemsSource="{Binding Plates}" HorizontalAlignment="Stretch" VerticalAlignment="Center" />
            <CheckBox Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Content="Julia Set" IsChecked="{Binding JuliaSet}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,5,0,5" />
        </Grid>
        <StackPanel Grid.Row="2" Margin="10,10,10,10" Orientation="Horizontal" HorizontalAlignment="Right" >
            <Button Content="Cancel" IsCancel="True" Width="60" Margin="0,0,10,0" />
            <Button Content="OK" IsDefault="True" Width="60" Command="{Binding AcceptCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}" />
        </StackPanel>
    </Grid>
</Window>
