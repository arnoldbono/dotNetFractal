<UserControl x:Class="dotNetFractal.WPF.Presentation.PropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:presentation="clr-namespace:dotNetFractal.WPF.Presentation"
             xmlns:converters="clr-namespace:dotNetFractal.WPF"
             xmlns:vm="clr-namespace:dotNetFractal.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:PropertiesPanelViewModel, IsDesignTimeCreatable=False}">
    <UserControl.Resources>
        <converters:BoolToCollapseSymbolConverter x:Key="BoolToCollapseSymbolConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Properties Panel - Expanded View -->
        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1,0,0,0" 
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <!-- Hide if panel is not visible OR if collapsed -->
                        <DataTrigger Binding="{Binding IsPropertiesPanelVisible}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ArePropertiesExpanded}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <!-- Header with buttons -->
                <Grid DockPanel.Dock="Top" Margin="5,5,5,10">
                    <Label Content="Properties" FontWeight="Bold" FontSize="14" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Collapse Button -->
                        <Button Content="{Binding ArePropertiesExpanded, Converter={StaticResource BoolToCollapseSymbolConverter}}" 
                                Width="24" Height="24" Margin="0,0,2,0" 
                                Command="{Binding CollapsePropertiesCommand}"
                                ToolTip="Collapse Panel"
                                FontSize="12" Padding="0"/>
                        <!-- Hide Button -->
                        <Button Content="✕" Width="24" Height="24" 
                                Command="{Binding HidePropertiesCommand}"
                                ToolTip="Hide Panel (F2 to show)"
                                FontSize="12" Padding="0"/>
                    </StackPanel>
                </Grid>

                <!-- Single Apply Button at bottom - MUST be before ScrollViewer -->
                <Border DockPanel.Dock="Bottom" Padding="5" BorderBrush="Gray" BorderThickness="0,1,0,0">
                    <Button Content="Apply" Padding="15,5" 
                            Command="{Binding ApplyFractalAreaCommand}" 
                            HorizontalAlignment="Center"
                            ToolTip="Apply all property changes and recompute fractal"/>
                </Border>

                <!-- Scrollable content - fills remaining space -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="5,0,5,5">
                        <!-- Fractal Area Expander -->
                        <Expander Header="Fractal Area" IsExpanded="True" Margin="0,0,0,5">
                            <StackPanel Margin="5">
                                <!-- Fractal Area Editor Control -->
                                <presentation:FractalAreaEditor DataContext="{Binding FractalAreaViewModel}" />
                            </StackPanel>
                        </Expander>

                        <!-- Image Resolution Expander -->
                        <Expander Header="Image Resolution" IsExpanded="False" Margin="0,0,0,5">
                            <StackPanel Margin="5">
                                <!-- Image Resolution Editor Control -->
                                <presentation:ImageResolutionEditor DataContext="{Binding ImageResolutionViewModel}" />
                            </StackPanel>
                        </Expander>

                        <!-- Color Map Expander -->
                        <Expander Header="Color Map" IsExpanded="False" Margin="0,0,0,5">
                            <StackPanel Margin="5">
                                <!-- Color Map Editor Control -->
                                <presentation:ColorMapEditor DataContext="{Binding ColorMapViewModel}" />
                            </StackPanel>
                        </Expander>

                        <!-- Fractal Settings Expander -->
                        <Expander Header="Fractal Settings" IsExpanded="False" Margin="0,0,0,5">
                            <StackPanel Margin="5">
                                <!-- Fractal Settings Editor Control -->
                                <presentation:FractalSettingsEditor DataContext="{Binding FractalSettingsViewModel}" />
                            </StackPanel>
                        </Expander>

                        <!-- Display Settings Expander -->
                        <Expander Header="Display Settings" IsExpanded="False" Margin="0,0,0,5">
                            <StackPanel Margin="5">
                                <!-- Display Settings Editor Control -->
                                <presentation:DisplaySettingsEditor DataContext="{Binding DisplaySettingsViewModel}" />
                            </StackPanel>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Properties Panel - Collapsed View (Narrow Strip) -->
        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1,0,0,0" 
                HorizontalAlignment="Right"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                Width="Auto">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <!-- Show collapsed strip only if panel is visible AND collapsed -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsPropertiesPanelVisible}" Value="True"/>
                                <Condition Binding="{Binding ArePropertiesExpanded}" Value="False"/>
                                <Condition Binding="{Binding IsFullScreen}" Value="False"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Button Content="{Binding ArePropertiesExpanded, Converter={StaticResource BoolToCollapseSymbolConverter}}" 
                    Width="24" Height="24" 
                    Margin="3,5,3,0"
                    VerticalAlignment="Top"
                    Command="{Binding CollapsePropertiesCommand}"
                    ToolTip="Expand Properties Panel (F2)"
                    FontSize="12" Padding="0"/>
        </Border>
    </Grid>
</UserControl>

