<Window x:Class="dotNetFractal.WPF.ColorMapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dotNetFractal.WPF"
        xmlns:presentation="clr-namespace:dotNetFractal.WPF.Presentation"
        xmlns:vm="clr-namespace:dotNetFractal.WPF.ViewModels"
        mc:Ignorable="d"
        Title="Fractal Color Map" Height="420" Width="450" ResizeMode="CanResize"
        d:DataContext="{d:DesignInstance Type=vm:ColorMapViewModel, IsDesignTimeCreatable=True}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Color Map Editor Control -->
        <presentation:ColorMapEditor Grid.Row="0" />

        <!-- OK button -->
        <Button Grid.Row="1" Content="OK" 
                IsDefault="True" 
                Width="60" 
                Margin="0,10,0,0"
                HorizontalAlignment="Right"
                Command="{Binding AcceptCommand}" 
                CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}" />
    </Grid>
</Window>
