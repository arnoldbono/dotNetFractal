<Window x:Class="dotNetFractal.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dotNetFractal.WPF"
        mc:Ignorable="d"
        Title=".NET Fractal (WPF Version)" Height="450" Width="800">
    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>
    <Grid>
        <StackPanel Orientation="Vertical">
            <Menu>
                <MenuItem Header="_File">
                    <MenuItem Header="_New" Command="{Binding NewFractalCommand}" />
                    <MenuItem Header="Save _As" Command="{Binding SaveAsCommand}" />
                </MenuItem>
                <MenuItem Header="_Edit">
                    <MenuItem Header="_Copy" />
                </MenuItem>
                <MenuItem Header="_Preferences">
                    <MenuItem Header="_Fractal Area" Command="{Binding FractalAreaCommand}" />
                    <MenuItem Header="_Image Resolution" Command="{Binding ImageResolutionCommand}" />
                </MenuItem>
            </Menu>
            <Image x:Name="FractalImage" Stretch="None" Source="{Binding MainImage}" Height="{Binding Height}" Width="{Binding Width}" VerticalAlignment="Top" HorizontalAlignment="Left"/>
        </StackPanel>
    </Grid>
</Window>
