<Window x:Class="dotNetFractal.WPF.ImageResolutionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dotNetFractal.WPF"
        mc:Ignorable="d"
        Title="Image Resolution" Height="220" Width="240" ResizeMode="NoResize">
    <Window.DataContext>
        <local:ImageResolutionViewModel />
    </Window.DataContext>
    <Window.Resources>
        <local:EnumBooleanConverter x:Key="EnumBooleanConverterKey"/>
    </Window.Resources>
    <Grid Margin="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Content="Select:"  VerticalAlignment="Center"/>
        <StackPanel Grid.Row="1" Margin="10,0,10,10" >
            <RadioButton GroupName="Resolution" Content="Full HD" HorizontalAlignment="Left" VerticalAlignment="Top"
                IsChecked="{Binding Path=SelectedResolution, Converter={StaticResource EnumBooleanConverterKey}, ConverterParameter={x:Static local:ResolutionEnum.FullHD}}" />
            <RadioButton GroupName="Resolution" Content="4K" HorizontalAlignment="Left" VerticalAlignment="Top"
                IsChecked="{Binding Path=SelectedResolution, Converter={StaticResource EnumBooleanConverterKey}, ConverterParameter={x:Static local:ResolutionEnum.UltraHD}}" />
            <RadioButton GroupName="Resolution" Content="Custom" HorizontalAlignment="Left" VerticalAlignment="Top"
                IsChecked="{Binding Path=SelectedResolution, Converter={StaticResource EnumBooleanConverterKey}, ConverterParameter={x:Static local:ResolutionEnum.Custom}}" />
        </StackPanel>
        <Grid Grid.Row="2" Margin="0,0,10,0" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="100"  />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Label Grid.Column="0" Grid.Row="0" Content="Width:"  VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="0" TextWrapping="Wrap" Text="{Binding Width}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" VerticalAlignment="Center"
                     IsReadOnly="{Binding ReadOnly}"/>
            <Label Grid.Column="0" Grid.Row="1" Content="Height:"  VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="1" TextWrapping="Wrap" Text="{Binding Height}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" VerticalAlignment="Center"
                     IsReadOnly="{Binding ReadOnly}"/>
        </Grid>
        <StackPanel Grid.Row="3" Margin="10,10,0,0" Orientation="Horizontal" HorizontalAlignment="Right" >
            <Button Content="Cancel" IsCancel="True" Width="60" Margin="0,0,10,0" />
            <Button Content="OK" IsDefault="True" Width="60" Command="{Binding AcceptCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}" />
        </StackPanel>
    </Grid>
</Window>
